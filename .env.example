# Copy to .env (gitignored) and fill in for LOCAL manual publishing only.
# In CI, PyPI uses Trusted Publishing (OIDC) — no token needed (see .github/workflows/publish.yml).

# PyPI API token, only for a manual `twine upload` from your machine.
# Create at https://pypi.org/manage/account/token/  (scope it to the `dutybeat` project once it exists).
PYPI_API_TOKEN=

# Base URL to test the client against a non-production API (optional).
DUTYBEAT_BASE_URL=https://api.dutybeat.com

# An API key to run integration checks by hand (optional; never commit a real value).
DUTYBEAT_API_KEY=
